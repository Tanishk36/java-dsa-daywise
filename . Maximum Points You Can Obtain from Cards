class Solution {
    public int maxScore(int[] cardPoints, int k) {
         int n=cardPoints.length;
        int leftsum=0;
        int rightsum=0;
        for(int i=0;i<k;i++){
            leftsum+=cardPoints[i];
        }
       int max=leftsum;
        int right=n-1;
        for(int i=k-1;i>=0;i--){
            leftsum=leftsum-cardPoints[i];
            rightsum+=cardPoints[right];
            right--;

            max=Math.max(max,leftsum+rightsum);
        }
        return max;
        
    }
}
